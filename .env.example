# ============================================================
# GITHUB AGENTS - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file — it contains secrets.
# ============================================================

# --- GitHub Configuration ---
# Personal Access Token (classic) with these scopes:
#   - repo (full control of private repos)
#   - workflow (update GitHub Action workflows)
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your GitHub repo in "owner/repo" format
GITHUB_REPOSITORY=your-username/your-repo

# --- Groq AI Configuration ---
# API key from: https://console.groq.com/keys
# Groq provides free, ultra-fast AI inference
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use:
#   - llama-3.3-70b-versatile  (best for code generation — RECOMMENDED)
#   - llama-3.1-8b-instant     (fastest, good for simple tasks)
#   - mixtral-8x7b-32768       (good balance of speed + quality)
GROQ_MODEL=llama-3.3-70b-versatile

# --- Optional: Slack Notifications ---
# Webhook URL for posting PR notifications to Slack
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
